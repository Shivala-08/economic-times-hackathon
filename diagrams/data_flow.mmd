graph LR
    subgraph Ingestion["📥 Ingestion Pipeline"]
        A[("📄 Raw Documents\nPDF, CSV, DOCX, TXT")] --> B["🔧 Parser\npdfplumber\npandas\ndocx"]
        B --> C["✂️ Chunker\n1024 tokens\n200 overlap"]
        C --> D["📐 Embedder\n384d vectors"]
        C --> E["🏷️ Entity Extractor\nspaCy + Regex\n11 entity types"]
    end

    subgraph Storage["🗄️ Storage"]
        D --> F[("🟦 ChromaDB\nVector Store")]
        E --> G["🕸️ NetworkX\nKnowledge Graph"]
        E --> F
    end

    subgraph Query["🔍 Query Pipeline"]
        H["❓ User Query"] --> I["📐 Embed Query\n(384d)"]
        H --> J["🏷️ Extract Entities"]
        I --> K["🔀 Hybrid Search\nBM25 + Vector"]
        K --> L["🎯 Cross-Encoder\nRe-rank"]
        L --> M["📊 Top-3 Chunks"]
        J --> N["🕸️ Graph Traversal\n1-hop neighbors"]
        N --> O["🔗 Graph Context\nEntities + Relations"]
    end

    subgraph Generation["🤖 Answer Generation"]
        M --> P["📝 Prompt Assembly\nDocument Context\n+ Graph Context\n+ Confidence Guide"]
        O --> P
        P --> Q["☁️ NVIDIA NIM\nStreaming"]
        Q --> R["📡 SSE Token Stream"]
    end

    subgraph Display["🖥️ UI Display"]
        R --> S["💬 Real-time\nToken Display"]
        S --> T["📚 Source\nCitations"]
        S --> U["🎯 Confidence\nScore"]
    end

    style Ingestion fill:#0f172a,stroke:#6366f1,stroke-width:2px,color:#f1f5f9
    style Storage fill:#060813,stroke:#3b82f6,stroke-width:2px,color:#f1f5f9
    style Query fill:#0a0e1a,stroke:#10b981,stroke-width:2px,color:#f1f5f9
    style Generation fill:#1a0a2e,stroke:#ec4899,stroke-width:2px,color:#f1f5f9
    style Display fill:#111827,stroke:#f59e0b,stroke-width:2px,color:#f1f5f9
