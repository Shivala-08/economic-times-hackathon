graph TD
    subgraph UI["🖥️ Streamlit Frontend"]
        Chat["💬 Chat Q&A\n(Streaming)"]
        Explorer["🔍 Knowledge Explorer\n(WebGL Graph)"]
        Benchmark["📊 Benchmark Runner"]
        Upload["📁 Document Upload"]
    end

    subgraph API["⚡ FastAPI Backend"]
        QuerySync["POST /query\n(Synchronous)"]
        QueryStream["POST /query/stream\n(SSE Streaming)"]
        BenchmarkAPI["GET /benchmark/run"]
        IngestAPI["POST /ingest/upload"]
        GraphAPI["GET /graph"]
    end

    subgraph Pipeline["🧠 Query Engine Pipeline"]
        Embedder["📐 Embedder\n(all-MiniLM-L6-v2\n384d)"]
        HybridSearch["🔀 Hybrid Search\nBM25 + Vector Fusion\nα=0.4"]
        CrossEncoder["🎯 Cross-Encoder Re-ranker\n(ms-marco-MiniLM-L-6-v2)"]
        GraphTraversal["🕸️ Graph 1-hop\nTraversal"]
        Cache["💾 Semantic Cache\n(500 entries\n0.95 threshold)"]
        Complexity["⚖️ Complexity\nClassifier"]
    end

    subgraph Storage["🗄️ Storage Layer"]
        ChromaDB[("🟦 ChromaDB\nVector Store\nCosine Similarity")]
        NetworkX["🕸️ NetworkX\nKnowledge Graph\n9 node types"]
        BM25["📝 BM25\nSparse Index"]
    end

    subgraph LLM["🤖 LLM Providers"]
        NvidiaNIM["☁️ NVIDIA NIM\nnemotron-3-ultra-550b\n10-key rotation"]
        Ollama["🏠 Ollama\nLocal Llama 3.1/3.2\n(Fallback)"]
    end

    Chat --> QueryStream
    Explorer --> GraphAPI
    Benchmark --> BenchmarkAPI
    Upload --> IngestAPI

    QuerySync --> Embedder
    QueryStream --> Embedder
    Embedder --> ChromaDB
    Embedder --> BM25
    ChromaDB --> HybridSearch
    BM25 --> HybridSearch
    HybridSearch --> CrossEncoder
    CrossEncoder --> Cache
    Cache -.->|Hit| QuerySync
    Cache -.->|Miss| Complexity
    Complexity --> NvidiaNIM
    NvidiaNIM -.->|All keys fail| Ollama

    IngestAPI --> Embedder
    IngestAPI --> NetworkX

    Explorer --> NetworkX
    GraphAPI --> NetworkX

